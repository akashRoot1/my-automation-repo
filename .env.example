# Copy this file to .env and fill in the values.
# Never commit the .env file to version control.

# ── LinkedIn Job Fetcher (GitHub Actions / local) ─────────────────────────────
# SMTP server settings – works with Mailgun, SendGrid, or any standard SMTP relay

# Hostname of the SMTP server (e.g. smtp.mailgun.org or smtp.sendgrid.net)
SMTP_HOST=smtp.mailgun.org

# SMTP port (587 for STARTTLS, 465 for SSL)
SMTP_PORT=587

# SMTP login username
#   Mailgun  → postmaster@mg.yourdomain.com
#   SendGrid → apikey  (literal string)
SMTP_USER=postmaster@mg.yourdomain.com

# SMTP password / API key
SMTP_PASS=your_smtp_password_or_api_key

# Sender address shown in the From: header
EMAIL_FROM=jobs-digest@yourdomain.com

# Recipient of the daily job digest
EMAIL_TO=akashvikram98@gmail.com

# ── Postgres ──────────────────────────────────────────────────────────────────
# Strong password for the n8n Postgres user
POSTGRES_PASSWORD=change_me_strong_password

# ── n8n ───────────────────────────────────────────────────────────────────────
# Random 32-character string used to encrypt stored credentials
# Generate one with: openssl rand -hex 16
N8N_ENCRYPTION_KEY=change_me_32char_random_key

# Protocol used to reach n8n (http or https)
N8N_PROTOCOL=http

# Hostname or IP where n8n is reachable (e.g. localhost or your domain)
N8N_HOST=localhost

# Full base URL for webhooks (must be reachable by external services)
WEBHOOK_URL=http://localhost:5678/

# Full base URL shown in the n8n editor UI
N8N_EDITOR_BASE_URL=http://localhost:5678/

# ── Timezone ──────────────────────────────────────────────────────────────────
# IANA timezone string – affects cron / Schedule Trigger nodes
TZ=UTC
