# Copy this file to .env and fill in the values before running docker compose.
# Never commit the .env file to version control.

# ── Postgres ──────────────────────────────────────────────────────────────────
# Strong password for the n8n Postgres user
POSTGRES_PASSWORD=change_me_strong_password

# ── n8n ───────────────────────────────────────────────────────────────────────
# Random 32-character string used to encrypt stored credentials
# Generate one with: openssl rand -hex 16
N8N_ENCRYPTION_KEY=change_me_32char_random_key

# Protocol used to reach n8n (http or https)
N8N_PROTOCOL=http

# Hostname or IP where n8n is reachable (e.g. localhost or your domain)
N8N_HOST=localhost

# Full base URL for webhooks (must be reachable by external services)
WEBHOOK_URL=http://localhost:5678/

# Full base URL shown in the n8n editor UI
N8N_EDITOR_BASE_URL=http://localhost:5678/

# ── Timezone ──────────────────────────────────────────────────────────────────
# IANA timezone string – affects cron / Schedule Trigger nodes
TZ=UTC
